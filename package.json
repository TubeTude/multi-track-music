{
  "name": "multi-track-music",
  "productName": "Multi-Track Music",
  "version": "1.0.0",
  "description": "Multi-Track Music — synced multi-track audio/video recorder",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dir": "electron-builder --mac --dir",
    "build:local": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.multitrackmusic.app",
    "productName": "Multi-Track Music",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.music",
      "artifactName": "MultiTrackMusic-${version}-universal.dmg",
      "hardenedRuntime": true,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.inherit.plist",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "dir",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "win": {
      "icon": "assets/musicmem.png",
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "MultiTrackMusic-Setup-${version}.exe"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "assets/**"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ]
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  }
}
